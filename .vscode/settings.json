{
   "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx1G -Xms100m -Xlog:disable",
   "highlight.regexes": 
   {  
      // Dims @SuppressWarnings ...
      "(@SuppressWarnings\\s*.*)":
      {
         "decorations": [
            {
                  "color": "#444444",   // grey
                  "opacity": "0.6",
                  "fontStyle": "italic"
            }
         ]
      },

   
      // Dims standard log calls and single-line trace/debug wrappers
      // Captures: log.debug("...")
      //           if(log.isTraceEnabled()){log.trace("...");} ...
      "(log\\.(trace|debug|info|warn|error)\\s*\\(.*?\\);)":
      {
         "decorations": [
            {
                  "color": "#444444",   // grey
                  "opacity": "0.6",
                  "fontStyle": "italic"
            }
         ]
      },
      "(if\\s*\\(\\s*log\\.is[A-Za-z]+Enabled\\(\\)\\s*\\)\\s*\\{?\\s*)?log\\.(trace|debug|info|warn|error)\\s*\\(.*?\\);\\s*\\}?": 
      {
         "decorations": [
            {
                  "color": "#444444",
                  "opacity": "0.6",
                  "fontStyle": "italic"
            }
         ]
      },
      "if\\s*\\(\\s*log\\.is[A-Za-z]+Enabled\\(\\)\\s*\\)\\s*\\{": 
      {
         "decorations": [
            {
                  "color": "#444444",
                  "opacity": "0.6",
                  "fontStyle": "italic"
            }
         ]
      }
   }
}
